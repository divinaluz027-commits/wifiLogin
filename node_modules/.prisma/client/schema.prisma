generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model User {
  id         Int      @id @default(autoincrement())
  nome       String
  email      String   @unique
  telefone   String
  macAddress String?
  ipAddress  String?
  criadoEm   DateTime @default(now())
}
